# Gemini API (출퇴근 단독 에이전트 등 Gemini 사용 시)
GOOGLE_API_KEY=your-gemini-api-key

# Hugging Face — 루트 에이전트 LLM
HF_TOKEN=hf_your_token_here
HF_MODEL_ID=openai/gpt-oss-120b
# HF_MODEL=huggingface/openai/gpt-oss-120b
# HF_INFERENCE_PROVIDER=

# ── 에이전트 접근 인증 (모바일 앱 로그인) ──
AGENT_USER_ID=your_login_id
AGENT_PASSWORD=your_login_password
AGENT_SECRET_KEY=long-random-string-for-token-signing
# 레거시 고정 토큰 (선택)
# CHAT_API_TOKEN=

# ── 배포 모드 ──
# local  = PC에서 직접 실행 (Tailscale)
# railway = Railway 클라우드 배포
DEPLOYMENT_MODE=local

# ── 로컬 PC 워커 (Railway 배포 시 PC에서 실행) ──
# Railway와 PC에 동일한 값 설정
WORKER_SECRET=long-random-worker-secret
# PC 워커 전용 (.env on PC)
# SERVER_URL=https://your-app.up.railway.app

# 메타빌드 그룹웨어 (출퇴근 도구)
GW_USER_ID=your_user_id
GW_PASSWORD=your_password
GW_BASE_URL=https://gw.metabuild.co.kr

CLOCK_IN_TIME=08:50
CLOCK_OUT_TIME=18:00
HEADLESS=true

# 서버 (로컬)
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# 메이플스토리 (로컬 PC 전용)
MAPLE_STORY_PATH=C:\Nexon\MapleStory\MapleStory.exe

# 한화오션 주식 (042660.KS)
HANWHA_OCEAN_TICKER=042660.KS
HANWHA_OCEAN_AVG_PRICE=125571
